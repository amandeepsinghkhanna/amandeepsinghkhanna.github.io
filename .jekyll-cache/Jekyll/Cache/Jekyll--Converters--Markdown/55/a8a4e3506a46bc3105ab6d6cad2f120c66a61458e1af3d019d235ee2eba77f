	<span class="n">spark</span><span class="p">.</span><span class="n">read</span><span class="p">.</span><span class="n">csv</span><span class="p">(</span>
		<span class="s">"filepath"</span><span class="p">,</span> <span class="n">header</span><span class="o">=</span><span class="bp">True</span><span class="p">,</span> <span class="n">inferSchema</span><span class="o">=</span><span class="bp">True</span>
	<span class="p">)</span>
<span class="p">)</span>

<span class="c1"># reading data from a '.txt' file:
